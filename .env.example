# Wisuno Carousel Automation — API Keys
# Copy this file to .env and fill in your values

# Required: Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Required for meme image generation: Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Optional: Higgsfield API — text-to-image via FLUX/Seedream (https://cloud.higgsfield.ai)
# Use --higgsfield flag to activate; format can be "key-id:key-secret" or just an API key
HIGGSFIELD_API_KEY=your-higgsfield-api-key

# Required for slide image search: Google Custom Search API
# 1. Create a Search Engine at https://programmablesearchengine.google.com
#    (enable "Search entire web" + "Image search", copy the cx ID)
# 2. Enable Custom Search API at https://console.cloud.google.com and create a key
GOOGLE_CSE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=946620894338-kjf5i000htpfkqgv4nv3mevgfo5evv7b.apps.googleusercontent.com
